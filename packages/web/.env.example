# theStats — packages/web env example.
# Copy to .env.local and fill in values from `supabase start` output.
# .env.local is gitignored — never commit it.

# ---- Public (safe to ship to browser bundles) ------------------------------

# Supabase project URL. For local dev this is the URL printed by
# `supabase start`, typically http://127.0.0.1:54321.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anonymous key. Safe to expose to the browser — RLS is the
# real boundary (see Constitution Principle VI / supabase migration 0001).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---- SERVER-ONLY (must NEVER ship to the browser) --------------------------
# Constitution Principle VI: the service_role key bypasses RLS and MUST
# NEVER be prefixed with NEXT_PUBLIC_, embedded in client bundles, or
# returned in any user-facing response. It is read only by code that
# imports "server-only" (currently only src/lib/supabase/admin.ts and
# the supabase server-side helpers).

SUPABASE_SERVICE_ROLE_KEY=
